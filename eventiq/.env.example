# Supabase (Required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth (Required for auth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apollo.io (Contact Enrichment)
APOLLO_API_KEY=

# HubSpot CRM (Bidirectional Sync)
HUBSPOT_API_KEY=

# Outplay (Email Sequences)
OUTPLAY_API_KEY=

# Hunter.io (Email Verification — optional)
HUNTER_API_KEY=

# Cron Security (Vercel cron secret)
CRON_SECRET=

# News Ingestion
# Comma-separated Google Alerts RSS feed URLs (create at https://www.google.com/alerts)
# See docs/GOOGLE_ALERTS_SETUP.md for setup instructions
GOOGLE_ALERT_RSS_URLS=

# Optional: Bing News API key for additional news coverage (1K queries/mo free tier)
BING_NEWS_API_KEY=
